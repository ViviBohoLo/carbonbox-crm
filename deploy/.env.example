# Config de producción del CRM CarbonBox (Twenty) en el VPS.
# Copiar a `.env` y rellenar los valores reales. NUNCA commitear el .env real.

TAG=latest

# --- Base de datos (Postgres local en el contenedor) ---
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=<GENERAR: openssl rand -hex 24>
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
REDIS_URL=redis://redis:6379

# --- Servidor ---
SERVER_URL=https://crm.carbonbox.app
# Clave para cifrar tokens (Google, etc.) en la BD. Generar: openssl rand -base64 32
# OJO: debe ser la MISMA con la que se cifró el dump de la BD, o los tokens no descifran.
ENCRYPTION_KEY=<GENERAR: openssl rand -base64 32>
STORAGE_TYPE=local

# --- Google Workspace (Gmail + Calendar) ---
# App OAuth en Google Cloud, proyecto "CarbonBox CRM" (tipo Interno).
AUTH_GOOGLE_ENABLED=true
MESSAGING_PROVIDER_GMAIL_ENABLED=true
CALENDAR_PROVIDER_GOOGLE_ENABLED=true
AUTH_GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com
AUTH_GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
AUTH_GOOGLE_CALLBACK_URL=https://crm.carbonbox.app/auth/google/redirect
AUTH_GOOGLE_APIS_CALLBACK_URL=https://crm.carbonbox.app/auth/google-apis/get-access-token

# --- Envío de correos desde alias (parche CarbonBox, ver rebrand/) ---
EMAIL_SEND_FROM_ALIAS=viviana.bohorquez@carbonbox.app
EMAIL_SEND_FROM_NAME=Viviana Bohorquez - CarbonBox
